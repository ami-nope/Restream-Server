# Restream Server Configuration
# Copy this file to .env and update values

# Stream key for OBS to authenticate with
# OBS pushes to: rtmp://<server-ip>:1935/live/<STREAM_KEY>
STREAM_KEY=your-secret-stream-key

# Backend port (default: 3001)
PORT=3001

# SRS hostname (default: srs — the Docker service name)
SRS_HOST=srs

# SRS API port (default: 1985)
SRS_API_PORT=1985

# SRS RTMP port (default: 1935)
SRS_RTMP_PORT=1935
