# Restream Server Configuration
# Copy this file to .env and update values

# OBS stream key is managed from the dashboard Settings page.
# First run uses the default key "live"; change or randomize it in the UI.

# Dashboard port exposed by Docker (default: 3000)
APP_PORT=3000

# SRS hostname (default: srs — the Docker service name)
SRS_HOST=srs

# SRS API port (default: 1985)
SRS_API_PORT=1985

# SRS RTMP port (default: 1935)
SRS_RTMP_PORT=1935
